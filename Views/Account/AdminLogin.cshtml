@model OstaFeedbackApp.Models.AdminLoginViewModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    Layout = null;
    var userEmail = User.Identity?.IsAuthenticated == true ? User.Identity.Name : null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        margin: 0;
        height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #1e90ff, #6c5ce7);
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-card {
        width: 380px;
        padding: 35px;
        border-radius: 16px;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        animation: fadeIn 0.6s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .title {
        font-weight: 700;
        color: #1e90ff;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px;
    }

    .btn-login, .btn-logout {
        border-radius: 25px;
        background: linear-gradient(90deg, #1e90ff, #6c5ce7);
        border: none;
        font-weight: 600;
    }

        .btn-login:hover, .btn-logout:hover {
            opacity: 0.9;
        }

    .footer-text {
        font-size: 12px;
        color: #777;
        text-align: center;
        margin-top: 15px;
    }
</style>

<div class="login-card">
    <div class="text-center mb-4">
        <h3 class="title">🔐 Admin Login</h3>
        <small class="text-muted">OSTA Feedback System</small>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="text-center mb-3">
            <p>Welcome back, <strong>@userEmail</strong>!</p>
            <form asp-action="Logout" method="post">
                <button type="submit" class="btn btn-logout w-100">Logout</button>
            </form>
        </div>
    }
    else
    {
        <form asp-action="AdminLogin" method="post">
            <div asp-validation-summary="All" class="text-danger mb-2"></div>

            <div class="mb-3">
                <input asp-for="Email" class="form-control" placeholder="Email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Remember me</label>
            </div>

            <button type="submit" class="btn btn-login w-100">Login</button>
        </form>
    }

    <div class="footer-text">© 2026 OSTA • Secure Admin Access</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}