@model OstaFeedbackApp.Models.Feedback
@using System.Text.Json

@{
    Layout = null;
    var questions = ViewBag.Questions as List<OstaFeedbackApp.Models.Question> ?? new List<OstaFeedbackApp.Models.Question>();
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>OSTA Exhibition Feedback Form</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(180deg, #004a99 0%, #ffffff 60%);
            font-family: "Segoe UI",sans-serif;
        }

        .header {
            background: #003366;
            color: white;
            padding: 20px;
            text-align: center;
        }

        .header img {
            max-height: 70px;
        }

        .main-content {
            max-width: 1100px;
            margin: auto;
            padding: 20px;
        }

        .form-section {
            background: #fff;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.08);
            margin-bottom: 25px;
        }

        .form-section h4 {
            color: #003366;
            margin-bottom: 15px;
        }

        .rating input {
            display: none;
        }

        .rating label {
            width: 40px;
            height: 40px;
            line-height: 40px;
            border-radius: 50%;
            background: #ddd;
            text-align: center;
            cursor: pointer;
            margin-right: 6px;
            transition: 0.3s;
        }

        .rating label:hover {
            transform: scale(1.1);
            background: #1E90FF;
            color: white;
        }

        .rating input:checked + label, .rating label.active {
            background: linear-gradient(135deg, #003366, #1E90FF);
            color: white;
        }

        textarea, input, select {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #ccc;
            margin-bottom: 5px;
        }

        .char-count {
            font-size: 12px;
            text-align: right;
            color: #888;
            margin-bottom: 10px;
        }

        .progress {
            height: 10px;
            border-radius: 10px;
        }

        .btn-primary {
            background: #003366;
            border: none;
            padding: 10px 25px;
            font-size: 16px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background: #1E90FF;
        }
    </style>
</head>
<body>
    <header class="header">
        <img src="~/images/osta-logo.webp" asp-append-version="true" />
        <h2>OSTA Exhibition Feedback Form</h2>
    </header>

    <div class="main-content">
        <!-- Progress Bar -->
        <div class="mb-3">
            <div class="progress">
                <div id="progressBar" class="progress-bar bg-primary" style="width:0%"></div>
            </div>
            <small id="progressText">0% completed</small>
        </div>

        <form asp-action="Create" method="post">
            <!-- Ratings Section -->
            <div class="form-section">
                <h4>🔹 Ratings</h4>
                <p class="text-muted">Scale: 1 = Very Poor | 5 = Excellent</p>

                @if (questions.Any())
                {
                    foreach (var q in questions)
                    {
                        <div class="mb-3 question">
                            <strong>
                                @{
                                    var text = q.TextEn;
                                    if (string.IsNullOrWhiteSpace(text)) text = q.TextOr;
                                    if (string.IsNullOrWhiteSpace(text)) text = q.TextAm;
                                    text ??= "Question not available";
                                }
                                @text
                            </strong>
                            <div class="rating">
                                @for (int i = 1; i <= q.MaxRating; i++)
                                {
                                    <input type="radio" id="@($"{q.Property}_{i}")" name="@q.Property" value="@i" required />
                                    <label for="@($"{q.Property}_{i}")">@i</label>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p>No questions available at this time.</p>
                }
            </div>

            <!-- Comments Section -->
            <div class="form-section">
                <h4>🔹 Comments <small class="text-muted">(Optional)</small></h4>
                <textarea asp-for="Impressed" maxlength="300" placeholder="What impressed you? (optional)"></textarea>
                <div class="char-count">0 / 300</div>

                <textarea asp-for="Improvement" maxlength="300" placeholder="What needs improvement? (optional)"></textarea>
                <div class="char-count">0 / 300</div>

                <textarea asp-for="DigitalService" maxlength="300" placeholder="Digital service ideas (optional)"></textarea>
                <div class="char-count">0 / 300</div>

                <textarea asp-for="YouthSupport" maxlength="300" placeholder="Youth suggestions (optional)"></textarea>
                <div class="char-count">0 / 300</div>
            </div>

            <!-- General Info Section -->
            <div class="form-section">
                <h4>🔹 General Information <small class="text-muted">(Optional)</small></h4>
                <select asp-for="AgeGroup">
                    <option value="">Select Age Group (optional)</option>
                    <option>Under 18</option>
                    <option>18–25</option>
                    <option>26–35</option>
                    <option>36–50</option>
                    <option>50+</option>
                </select>
                <input asp-for="Occupation" placeholder="Occupation (optional)" />
                <input asp-for="Region" placeholder="Region/City (optional)" />
            </div>

            <button id="submitBtn" class="btn btn-primary w-100" disabled>🚀 Submit Feedback</button>
        </form>
    </div>

    <script>
        const questionsData = @Html.Raw(JsonSerializer.Serialize(questions.Select(q => new { q.Property, q.IsRequired })));
        const totalRequired = questionsData.length;

        const progressBar = document.getElementById("progressBar");
        const progressText = document.getElementById("progressText");
        const submitBtn = document.getElementById("submitBtn");

        function updateProgress() {
            const checked = document.querySelectorAll(".rating input:checked").length;
            const percent = totalRequired === 0 ? 100 : Math.floor((checked / totalRequired) * 100);
            submitBtn.disabled = checked < totalRequired;
            progressBar.style.width = percent + "%";
            progressText.innerText = percent + "% completed";
        }

        document.querySelectorAll(".rating input").forEach(input => {
            input.addEventListener("change", function() {
                const group = this.closest(".rating");
                if (group) group.querySelectorAll("label").forEach(l => l.classList.remove("active"));
                const label = document.querySelector(`label[for='${this.id}']`);
                if (label) label.classList.add("active");
                updateProgress();
            });
        });

        document.querySelectorAll("textarea[maxlength]").forEach(txt => {
            const charCount = txt.nextElementSibling;
            txt.addEventListener("input", () => {
                if (charCount) charCount.innerText = `${txt.value.length} / ${txt.maxLength}`;
            });
        });

        updateProgress();
    </script>
</body>
</html>
