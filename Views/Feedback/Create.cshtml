    <!-- Scripts -->
    <script>
        // Inject questions array for progress calculation
        const questionsData = @Html.Raw(JsonSerializer.Serialize(questions.Select(q => new { q.Property, q.IsRequired })));
        const totalRequired = questionsData.length;

        const progressBar = document.getElementById("progressBar");
        const progressText = document.getElementById("progressText");
        const submitBtn = document.getElementById("submitBtn");

        function updateProgress() {
            const checked = document.querySelectorAll(".rating input:checked").length;
            const percent = totalRequired === 0 ? 100 : Math.floor((checked / totalRequired) * 100);
            submitBtn.disabled = checked < totalRequired;
            progressBar.style.width = percent + "%";
            progressText.innerText = percent + "% completed";
        }

        // Rating stars click
        document.querySelectorAll(".rating input").forEach(input => {
            input.addEventListener("change", function() {
                const group = this.closest(".rating");
                if (group) {
                    group.querySelectorAll("label").forEach(l => l.classList.remove("active"));
                    const label = document.querySelector(`label[for='${this.id}']`);
                    if (label) label.classList.add("active");
                }
                updateProgress();
            });
        });

        // Character count for textareas
        document.querySelectorAll("textarea[maxlength]").forEach(txt => {
            const charCount = txt.nextElementSibling;
            txt.addEventListener("input", () => {
                if (charCount) charCount.innerText = `${txt.value.length} / ${txt.maxLength}`;
            });
        });

        // Initialize
        updateProgress();
    </script>
