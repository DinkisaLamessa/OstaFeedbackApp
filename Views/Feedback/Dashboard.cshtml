<script>
    const data = @Html.Raw(dataJson);
    const metrics = ["Commitment","Transparency","Innovation","CommunityImpact","YouthOpportunity"];
    let filtered = [...data];

    // --- KPI ---
    function avg(metric){
        return filtered.length ? filtered.reduce((sum, x) => sum + (x[metric] || 0), 0)/filtered.length : 0;
    }

    function renderKPI(){
        const kpiHtml = metrics.map(m=>`
            <div class="col-md-2 col-6 mb-3">
                <div class="card-x text-center">
                    <div>${m}</div>
                    <div class="kpi">${avg(m).toFixed(1)}</div>
                </div>
            </div>
        `).join('') + `
            <div class="col-md-2 col-6 mb-3">
                <div class="card-x text-center">
                    <div>Total</div>
                    <div class="kpi">${filtered.length}</div>
                </div>
            </div>
        `;
        document.getElementById("kpi").innerHTML = kpiHtml;
    }

    // --- CHARTS ---
    let barChart, lineChart, pieChart, histChart;

    function renderCharts(){
        const ctxBar = document.getElementById("barChart").getContext('2d');
        const ctxLine = document.getElementById("lineChart").getContext('2d');
        const ctxPie = document.getElementById("pieChart").getContext('2d');
        const ctxHist = document.getElementById("histChart").getContext('2d');

        // Destroy existing charts to avoid duplicates
        [barChart,lineChart,pieChart,histChart].forEach(c=>c?.destroy());

        // Bar Chart
        barChart = new Chart(ctxBar,{
            type:'bar',
            data:{
                labels:metrics,
                datasets:[{
                    label:'Average Rating',
                    data:metrics.map(avg),
                    backgroundColor:'#1e90ff'
                }]
            },
            options:{responsive:true, plugins:{legend:{display:false}}}
        });

        // Pie Chart
        pieChart = new Chart(ctxPie,{
            type:'pie',
            data:{
                labels:metrics,
                datasets:[{
                    data:metrics.map(avg),
                    backgroundColor:['#1e90ff','#00b894','#fdcb6e','#e17055','#6c5ce7']
                }]
            },
            options:{responsive:true}
        });

        // Line Chart (Trend)
        const dates = {};
        filtered.forEach(x=>{
            const d = new Date(x.CreatedAt).toLocaleDateString();
            dates[d] = (dates[d]||0)+1;
        });
        lineChart = new Chart(ctxLine,{
            type:'line',
            data:{
                labels:Object.keys(dates),
                datasets:[{
                    label:'Submissions',
                    data:Object.values(dates),
                    borderColor:'#00b894',
                    backgroundColor:'rgba(0,184,148,0.2)',
                    tension:0.2,
                    fill:true
                }]
            },
            options:{responsive:true}
        });

        // Histogram – aggregated counts for ratings 1–5 across all metrics
        const ratingValues = [1,2,3,4,5];
        const aggregatedCounts = ratingValues.map(rating => {
            return filtered.reduce((total, item) => {
                return total + metrics.reduce((sum, metric) => sum + (item[metric] === rating ? 1 : 0), 0);
            }, 0);
        });
        histChart = new Chart(ctxHist,{
            type:'bar',
            data:{
                labels:["1","2","3","4","5"],
                datasets:[{
                    label:'Rating Count (All Questions)',
                    data:aggregatedCounts,
                    backgroundColor:'#fd79a8'
                }]
            },
            options:{responsive:true}
        });
    }

    // --- TABLE ---
    function renderTable(){
        const search = document.getElementById("search").value.toLowerCase();
        const rows = filtered.filter(x =>
            !search || Object.values(x).some(v=>v?.toString().toLowerCase().includes(search))
        );

        document.getElementById("tbl").innerHTML =
            rows.map((x,i)=>`
                <tr>
                    <td>${i+1}</td>
                    <td>${x.Department||'-'}</td>
                    <td>${new Date(x.CreatedAt).toLocaleDateString()}</td>
                    <td>${x.Commitment}</td>
                    <td>${x.Transparency}</td>
                    <td>${x.Innovation}</td>
                    <td>${x.CommunityImpact}</td>
                    <td>${x.YouthOpportunity}</td>
                </tr>
            `).join('');
    }

    // --- FILTERS ---
    function applyFilters(){
        const dept = document.getElementById("dept").value;
        const from = document.getElementById("from").value;
        const to = document.getElementById("to").value;

        filtered = data.filter(x=>{
            const date = new Date(x.CreatedAt);
            return (!dept || x.Department===dept) &&
                   (!from || date >= new Date(from)) &&
                   (!to || date <= new Date(to));
        });
        renderAll();
    }

    function resetFilters(){
        document.getElementById("dept").value = '';
        document.getElementById("from").value = '';
        document.getElementById("to").value = '';
        document.getElementById("search").value = '';
        filtered = [...data];
        renderAll();
    }

    // --- DARK MODE ---
    document.getElementById("darkToggle").addEventListener('click', ()=>{
        document.body.classList.toggle("dark-mode");
        localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
    });

    // persist dark mode
    if(localStorage.getItem('darkMode')==='true') document.body.classList.add('dark-mode');

    function renderAll(){
        renderKPI();
        renderCharts();
        renderTable();
    }

    renderAll();
