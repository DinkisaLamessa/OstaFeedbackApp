﻿@using System.Text.Json
@{
    Layout = null;

    var questions = ViewBag.Questions as List<OstaFeedbackApp.Models.Question> ?? new();
    var averages = ViewBag.Averages as Dictionary<string, double> ?? new();
    var insight = ViewBag.Insight as string ?? "Thank you for your feedback!";

    // Friendly labels (use TextEn instead of Property)
    var labels = questions.Select(q =>
        string.IsNullOrWhiteSpace(q.TextEn) ? q.Property : q.TextEn
    ).ToList();

    var data = questions.Select(q =>
        averages.ContainsKey(q.Property) ? averages[q.Property] : 0
    ).ToList();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Feedback Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            background: linear-gradient(135deg, #0a2540, #1E90FF);
            font-family: 'Segoe UI', sans-serif;
            color: white;
            padding: 20px;
        }

        .dashboard {
            max-width: 1100px;
            margin: auto;
        }

        .card-x {
            background: rgba(255,255,255,0.95);
            color: #333;
            border-radius: 16px;
            padding: 20px;
            margin-top: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .title {
            font-size: 26px;
            font-weight: bold;
        }

        .badge-score {
            display: inline-block;
            padding: 10px 18px;
            border-radius: 25px;
            font-weight: 600;
            color: white;
        }

        .excellent {
            background: #28a745;
        }

        .good {
            background: #1E90FF;
        }

        .average {
            background: #ffc107;
            color: black;
        }

        .poor {
            background: #dc3545;
        }

        canvas {
            max-height: 300px;
        }
    </style>
</head>

<body>

    <div class="dashboard">

        <!-- HEADER -->
        <div class="text-center">
            <div class="title">🎉 Thank You!</div>
            <p>Your feedback helps us improve digital services.</p>
        </div>

        <!-- INSIGHT -->
        <div class="card-x text-center">
            <h5>🧠 Experience Insight</h5>
            <p style="font-size:18px;">@insight</p>

            @{
                var avg = data.Any() ? data.Average() : 0;
                var badgeClass = avg >= 4.5 ? "excellent" :
                avg >= 3.5 ? "good" :
                avg >= 2.5 ? "average" : "poor";
                var label = avg >= 4.5 ? "Excellent Experience" :
                avg >= 3.5 ? "Good Experience" :
                avg >= 2.5 ? "Average Experience" :
                "Needs Improvement";
            }

            <div class="badge-score @badgeClass">@label</div>
        </div>

        <!-- BAR CHART -->
        <div class="card-x">
            <h5>📊 Service Performance</h5>
            <canvas id="barChart"></canvas>
        </div>

        <!-- RADAR CHART -->
        <div class="card-x">
            <h5>🕸️ Overall Experience Map</h5>
            <canvas id="radarChart"></canvas>
        </div>

    </div>

    <script>
        // Serialize data from Razor
        const labels = @Html.Raw(JsonSerializer.Serialize(labels));
        const data = @Html.Raw(JsonSerializer.Serialize(data));

        // Only create charts if there is data to display
        if (labels.length > 0 && data.length > 0) {
            // BAR CHART
            new Chart(document.getElementById('barChart'), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: 'rgba(30,144,255,0.6)',
                        borderColor: '#1E90FF',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, max: 5 } }
                }
            });

            // RADAR CHART
            new Chart(document.getElementById('radarChart'), {
                type: 'radar',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: 'rgba(30,144,255,0.2)',
                        borderColor: '#1E90FF',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    scales: { r: { min: 0, max: 5, ticks: { stepSize: 1 } } }
                }
            });
        } else {
            // Show a message if no data is available
            document.getElementById('barChart').style.display = 'none';
            document.getElementById('radarChart').style.display = 'none';
            const noDataMsg = document.createElement('div');
            noDataMsg.className = 'card-x text-center';
            noDataMsg.innerHTML = '<p>No feedback data available yet.</p>';
            document.querySelector('.dashboard').appendChild(noDataMsg);
        }

        // 🔄 Redirect after 10 seconds (or show a message with countdown)
        setTimeout(() => {
            window.location.href = "https://osta.gov.et/";
        }, 10000);
    </script>

